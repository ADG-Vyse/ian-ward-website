---
import { Image } from "astro:assets";

interface Props {
	image: ImageMetadata;
	alt?: string;
}

const { image, alt = "" } = Astro.props;
const dialogId = `gallery-dialog-${crypto.randomUUID()}`;
---

<div class="gallery-image">
	<button onclick={`document.getElementById('${dialogId}').showModal()`} aria-label="View full image">
		<Image src={image} alt={alt} />
	</button>
	<dialog id={dialogId} onclick={`document.getElementById('${dialogId}').close()`}>
		<img src={image.src} alt={alt} />
	</dialog>
</div>

<style>
	.gallery-image {
		overflow: hidden;
	}

	button {
		all: unset;
		cursor: pointer;
		display: block;
		width: 100%;
		height: 100%;
	}

	button img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.2s ease;
	}

	button:hover img {
		transform: scale(1.03);
	}

	dialog {
		padding: 0;
		background: transparent;
		border: none;
		max-width: 90vw;
		max-height: 90vh;
		opacity: 1;
		transform: scale(1);
		transition: opacity 0.2s ease, transform 0.2s ease, display 0.2s ease allow-discrete, overlay 0.2s ease allow-discrete;
	}

	@starting-style {
		dialog[open] {
			opacity: 0;
			transform: scale(0.9);
		}
	}

	dialog img {
		max-width: 90vw;
		max-height: 90vh;
		object-fit: contain;
		display: block;
	}

	dialog::backdrop {
		background-color: rgb(0 0 0 / 0.85);
		cursor: pointer;
		opacity: 1;
		transition: opacity 0.2s ease, display 0.2s ease allow-discrete, overlay 0.2s ease allow-discrete;
	}

	@starting-style {
		dialog[open]::backdrop {
			opacity: 0;
		}
	}
</style>
