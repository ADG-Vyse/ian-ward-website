---
import "@/styles/global.css";
import NavLink from "@/components/nav-link.astro";
import { navLinks } from "@/data/links";

const currentPath = Astro.url.pathname;

function isLinkHighlighted(href: string) {
	if (currentPath === href) {
		return true;
	}

	if (currentPath.includes("work") && href === "/") {
		return true;
	}

	return false;
}
---

<nav>
	{
		navLinks.map((link) => (
			<NavLink href={link.href} name={link.name} isCurrent={isLinkHighlighted(link.href)} />
		))
	}
</nav>

<style>
	nav {
		display: flex;
		flex-direction: column;
		gap: 0;
		justify-content: start;
		text-align: left;
	}
</style>
