---
import "@/styles/global.css";

interface Props {
	href: string;
	name: string;
}

const { href, name } = Astro.props;
const currentPath = Astro.url.pathname;

function isLinkHighlighted(href: string) {
	if (currentPath === href) {
		return true;
	}

	if (currentPath.includes("work") && href === "/") {
		return true;
	}

	return false;
}

const isCurrent = isLinkHighlighted(href);
---

<a href={href} class={isCurrent ? "current-page" : ""}>
	{name}
</a>

<style>
	a {
		padding: 0.75rem 0.5rem;
		color: var(--text-color);
		transition-duration: 100ms;
		transition-property: color;
	}

	a:hover {
		color: white;
	}

	.current-page {
		color: white;
	}
</style>
