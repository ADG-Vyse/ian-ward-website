---
import "@/styles/global.css";
import type { IconType } from "react-icons";

interface Props {
	href: string;
	name: string;
	Icon: IconType;
}

const { href, name, Icon } = Astro.props;
---

<a href={href} class="accented-border">
	<Icon />
	<span>{name}</span>
</a>

<style>
	a {
		display: flex;
		align-items: center;
		gap: 0.4rem;

		height: fit-content;
		width: fit-content;

		padding: 0.75rem 0.75rem;
		border-radius: 0.75rem;

		color: var(--text-color);
		background-color: hsl(from white h s calc(l * 0.03));

		transition-duration: 0.4s;
		transition-property: color, background-color, border-color;
	}

	a:hover {
		color: white;
		background-color: hsl(from white h s calc(l * 0.1));
	}
</style>
