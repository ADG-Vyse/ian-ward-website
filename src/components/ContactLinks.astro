---
import "../styles/global.css";
import { FiLinkedin } from "react-icons/fi";
import { FiMail } from "react-icons/fi";

const { footer } = Astro.props as { footer?: boolean };

const links = [
	{
		name: "Linkedin",
		href: "https://www.linkedin.com/in/ian-ward-567594177/",
		Icon: FiLinkedin,
	},
	{
		name: "Email",
		href: "mailto:IanWard1991@hotmail.co.uk",
		Icon: FiMail,
	},
];
---

<div class:list={[{ footer }]}>
	{
		links.map(({ href, Icon, name }) => (
			<a href={href} class="accented-border">
				<Icon />
				<span class:list={[{ footer }]}>{name}</span>
			</a>
		))
	}
</div>

<style>
	div {
		display: flex;
		gap: 0.5rem;
		user-select: none;
		justify-content: flex-end;
	}

	div.footer {
		justify-content: flex-start;
		flex-direction: column;
	}

	a {
		display: flex;
		align-items: center;
		gap: 0.4rem;

		height: fit-content;
		width: fit-content;

		padding: 0.75rem 0.75rem;
		border-radius: 0.75rem;

		color: var(--text-color);
		background-color: hsl(from white h s calc(l * 0.03));

		transition-duration: 0.4s;
		transition-property: color, background-color, border-color;
	}

	a:hover {
		color: white;
		background-color: hsl(from white h s calc(l * 0.1));
	}

	@media (max-width: 750px) {
		div {
			display: none;
		}
		div.footer {
			display: flex;
			align-items: center;
		}
	}
</style>
