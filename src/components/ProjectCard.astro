---
import "../styles/global.css";
import { FiUser } from "react-icons/fi";

interface Props {
	title: string;
	description: string;
	image: string;
	alt: string;
	role: string;
	tags: string[];
	link: string;
}

const { title, description, image, alt, role, tags, link } =
	Astro.props as Props;
---

<a href={link} class="accented_border card">
	<div class="image_container">
		<img src={image} alt={alt} />
	</div>
	<div class="content">
		<h3>{title}</h3>
		<p>{description}</p>
		<span class="role"><FiUser /> {role}</span>
		<div class="tags">
			{tags.map((tag) => <span class="badge">{tag}</span>)}
		</div>
	</div>
</a>

<style>
	.card {
		border-radius: 0.75rem;
		overflow: hidden;
		background-color: rgb(14 17 22 / 0.3);
	}

	a {
		display: grid;
		grid-template-rows: minmax(0, 50%) 1fr;
		height: 30rem;
	}

	.image_container {
		overflow: hidden;
		height: 100%;
	}

	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		transition-duration: 0.4s;
		transition-property: transform;
	}

	img:hover {
		transform: scale(1.25);
	}

	.content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
	}

	h3 {
		color: white;
		font-weight: normal;
		margin: 0;
	}

	.role {
		margin-top: auto;
		display: inline-flex;
		gap: 0.75rem;
		align-items: center;
		color: hsl(from white h s calc(l * 0.5));
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.75rem;
	}
</style>
