---
import "normalize.css";
import "../styles/global.css";
import NavLinks from "../components/NavLinks.astro";
import ContactLinks from "../components/ContactLinks.astro";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Ian Ward</title>
	</head>
	<body>
		<header>
			<div class="container" id="navbar">
				<a href="/" id="page-title"><span>Ian Ward</span></a>
				<NavLinks />
				<ContactLinks />
			</div>
		</header>

		<slot />

		<footer>
			<div class="container">
				<span>Ian Ward</span>
			</div>
		</footer>
	</body>
</html>

<style>
	html {
		overflow: scroll;
	}
	body {
		grid-template-columns: 1fr;
		grid-template-rows: auto 1fr auto;
		background-color: black;
		color: var(--text-color);
		font-family: var(--font-sans);
	}

	header {
		padding: 1rem 0;
		border-bottom: 1px solid hsl(from white h s calc(l * 0.1));
		margin-bottom: 1rem;
	}

	footer {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		padding: 1rem 0;
		border-top: 1px solid hsl(from white h s calc(l * 0.1));
		margin-top: 1.5rem;
	}

	#navbar {
		display: grid;
		grid-template-columns: 1fr 4fr 1fr;
		align-items: center;
	}

	@media (max-width: 650px) {
		#navbar {
			grid-template-columns: 1fr 1fr;
			gap: 0.75rem;
		}
	}
	#page-title {
		color: white;
		padding: 0.75rem 0.5rem;
	}
</style>
