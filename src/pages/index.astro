---
import Gradient from "@/components/gradient.astro";
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/project-card.astro";
import "@/styles/global.css";
import { projects } from "@/data/projects";
---

<Layout>
	<Gradient color="purple" opacity={5}>
		<section class="container">
			<h1>Crafting Immersive Gaming Experiences</h1>
			<div id="expertise">
				<span class="badge">GAME DESIGNER</span>
				<span class="badge">LEVEL DESIGNER</span>
				<span class="badge">QUALITY ASSURANCE</span>
			</div>

			<p>
				I’m an aspiring game designer currently looking to start my
				career in the games industry. I have a degree (Hons) Computer
				Games (Design) (BCGD).
			</p>
		</section>
	</Gradient>

	<Gradient color="blue" opacity={5}>
		<section class="container">
			<h2>Featured Projects</h2>
			<p>
				A collection of game design projects showcasing my expertise in
				various genres and gameplay mechanics.
			</p>

			<div class="projects">
				{projects.map((project) => (
					<ProjectCard
						title={project.title}
						description={project.shortDescription}
						image={project.thumbnailImage}
						alt={project.thumbnailAltText}
						role={project.role}
						tags={project.tags}
						link={`/project/${project.projectLink}/`}
					/>
				))}
			</div>
		</section>
	</Gradient>
</Layout>

<style>
	h1 {
		color: white;
		text-align: center;
		font-size: clamp(2.1rem, 4vw, 2.5rem);
		margin-bottom: 2rem;
	}

	#expertise {
		display: flex;
		gap: 0.75rem;
		margin: 1.25rem 0;
		justify-content: center;
		flex-wrap: wrap;
		margin: 0 auto;
	}

	p {
		text-align: center;
		text-wrap: balance;
		margin: 2rem 0;
	}

	h2 {
		color: white;
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
		text-align: center;
	}

	.projects {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(min(500px, 100%), 1fr));
		gap: 1.5rem;
	}
</style>
