---
import Layout from "@/layouts/Layout.astro";
import "@/styles/global.css";
import { FiDownload } from "react-icons/fi";
---

<Layout>
	<div class="container">
		<div class="content">
			<h1>Resume</h1>
			<a class="accented-border" href="/IanWard_Resume.pdf" download>
				<FiDownload className="icon" /> Download
			</a>
		</div>
		<embed src="/IanWard_Resume.pdf" type="application/pdf" />
	</div>
</Layout>


<style>

	.content {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		gap: 1.5rem;
	}

	embed {
		width: 100%;
		height: 80vh
	}

	a {
		display: flex;
		align-items: center;
		border-radius: 0.75rem;
		padding: 0.75rem 0.75rem;

		width: fit-content;

		transition-duration: 0.4s;
		transition-property: color, background-color, border-color;
	}

	.icon {
		margin-right: 0.4rem;
	}

	a:hover {
		color: white;
		background-color: hsl(from white h s calc(l * 0.1));
	}
</style>
